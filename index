<!doctype html>
<html lang="ja">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>工事管理くん</title>

<style>
:root {
  --bg: #0b0b0b;
  --card: #151515;
  --text: #ffffff;
  --sub: #aaa;
  --gold: #d4af37;
}

body {
  margin: 0;
  background: var(--bg);
  color: var(--text);
  font-family: -apple-system, BlinkMacSystemFont;
}

.header {
  padding: 16px;
  font-size: 20px;
  font-weight: bold;
}

.search {
  padding: 0 16px 10px;
}

.search input {
  width: 100%;
  padding: 10px;
  border-radius: 10px;
  border: none;
  background: #1f1f1f;
  color: white;
}

.tabs {
  display: flex;
  gap: 8px;
  padding: 10px 16px;
  overflow-x: auto;
}

.tab {
  padding: 6px 12px;
  background: #1a1a1a;
  border-radius: 20px;
  font-size: 12px;
}

.tab.active {
  background: var(--gold);
  color: black;
}

.list {
  padding: 16px;
}

.card {
  background: var(--card);
  border-radius: 16px;
  padding: 14px;
  margin-bottom: 12px;
  cursor: pointer;
}

.title {
  font-size: 16px;
  font-weight: bold;
}

.status {
  float: right;
  font-size: 12px;
  padding: 2px 8px;
  border-radius: 8px;
}

.status.blue { background:#2d6cdf;}
.status.orange { background:#ff8c00;}
.status.green { background:#2ecc71;}

.sub {
  color: var(--sub);
  font-size: 12px;
  margin-top: 4px;
}

.tags {
  display: flex;
  gap: 6px;
  margin-top: 10px;
}

.tag {
  background: #222;
  padding: 4px 8px;
  border-radius: 8px;
  font-size: 11px;
}

.bottom {
  display: flex;
  justify-content: space-between;
  margin-top: 10px;
  font-size: 11px;
}

.fab {
  position: fixed;
  right: 20px;
  bottom: 20px;
  background: var(--gold);
  color: black;
  width: 55px;
  height: 55px;
  border-radius: 50%;
  font-size: 30px;
  text-align: center;
  line-height: 55px;
}

.modal {
  position: fixed;
  bottom: -100%;
  left: 0;
  right: 0;
  background: #111;
  padding: 20px;
  transition: .3s;
}

.modal.show {
  bottom: 0;
}

.modal input {
  width: 100%;
  margin-bottom: 10px;
  padding: 10px;
  border-radius: 8px;
  border: none;
  background: #222;
  color: white;
}

.btn {
  background: var(--gold);
  padding: 10px;
  text-align: center;
  border-radius: 10px;
  color: black;
}

.detail {
  display: none;
  padding: 16px;
}

.tabs2 {
  display: flex;
  gap: 10px;
  margin-top: 10px;
}

.tabs2 div {
  padding: 6px 10px;
  background: #222;
  border-radius: 8px;
  font-size: 12px;
}
</style>
</head>

<body>

<div class="header">工事管理くん</div>

<div class="search">
  <input placeholder="案件名・顧客名・住所で検索">
</div>

<div class="tabs">
  <div class="tab active">すべて</div>
  <div class="tab">見積中</div>
  <div class="tab">施工中</div>
  <div class="tab">完了</div>
</div>

<div class="list" id="list"></div>

<div class="fab" onclick="openModal()">＋</div>

<!-- モーダル -->
<div class="modal" id="modal">
  <input id="name" placeholder="案件名">
  <input id="customer" placeholder="顧客名">
  <input id="address" placeholder="住所">
  <div class="btn" onclick="addProject()">追加</div>
</div>

<!-- 詳細 -->
<div class="detail" id="detail">
  <div onclick="back()">← 戻る</div>
  <h2 id="d_name"></h2>

  <div class="tabs2">
    <div>図面</div>
    <div>見積</div>
    <div>写真</div>
    <div>メモ</div>
    <div>QR</div>
  </div>

  <p>ここにデータ表示</p>
</div>

<script>
let projects = [
  {name:"カフェ新装工事",customer:"HALL",address:"大阪",status:"blue"},
  {name:"厨房改修",customer:"山田商店",address:"堺市",status:"orange"}
];

function render(){
  const list = document.getElementById("list");
  list.innerHTML = "";
  projects.forEach((p,i)=>{
    list.innerHTML += `
      <div class="card" onclick="openDetail(${i})">
        <div class="title">
          ${p.name}
          <span class="status ${p.status}">${statusText(p.status)}</span>
        </div>
        <div class="sub">顧客：${p.customer}</div>
        <div class="sub">現場：${p.address}</div>
        <div class="tags">
          <div class="tag">図面2</div>
          <div class="tag">見積1</div>
          <div class="tag">写真5</div>
        </div>
        <div class="bottom">
          <div>更新：今日</div>
          <div>QR</div>
        </div>
      </div>
    `;
  });
}

function statusText(s){
  if(s==="blue") return "施工中";
  if(s==="orange") return "見積中";
  return "完了";
}

function openModal(){
  document.getElementById("modal").classList.add("show");
}

function addProject(){
  const name = document.getElementById("name").value;
  const customer = document.getElementById("customer").value;
  const address = document.getElementById("address").value;

  projects.push({name,customer,address,status:"blue"});
  document.getElementById("modal").classList.remove("show");
  render();
}

function openDetail(i){
  document.getElementById("list").style.display="none";
  document.querySelector(".tabs").style.display="none";
  document.querySelector(".search").style.display="none";
  document.getElementById("detail").style.display="block";

  document.getElementById("d_name").innerText = projects[i].name;
}

function back(){
  document.getElementById("list").style.display="block";
  document.querySelector(".tabs").style.display="flex";
  document.querySelector(".search").style.display="block";
  document.getElementById("detail").style.display="none";
}

render();
</script>

</body>
</html>
